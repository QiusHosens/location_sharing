# Docker Compose 绑定挂载产生的本地数据（保留 data/.gitkeep）
data/*
!data/.gitkeep

# 环境变量与密钥（勿提交）
.env
.env.local
.env.*.local
!.env.example
!**/.env.example
**/secrets.yaml

# Rust
**/target/
**/*.rs.bk

# Node / 前端 (admin, web)
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Flutter / Dart
**/doc/api/
**/.dart_tool/
**/build/
**/flutter_export_environment.sh
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/*.iml
**/Generated.xcconfig
**/ephemeral/

# HarmonyOS / DevEco
**/.hvigor/
**/oh_modules/
**/local.properties
**/.preview/

# 日志与临时文件
*.log
*.tmp
*.temp
.cache/

# 操作系统
.DS_Store
Thumbs.db
Desktop.ini

# IDE（按需取消注释）
.idea/
*.swp
*.swo
