# 若改过已应用的 migrations/*.sql，首次启动可设 1 同步校验和（改完后需重新 cargo build，仅本地）
# SQLX_MIGRATE_REPAIR=1
# 生产若不希望服务启动时自动执行迁移，可设为 0 / false
# SQLX_MIGRATE_ON_START=0

# 在 DATABASE_URL 中直接设时区（PostgreSQL/libpq）：options=-c TimeZone=Asia/Shanghai
# 注意 options 需 URL 编码：-c%20TimeZone%3DAsia%2FShanghai
# 密码中的 '@' 需编码为 '%40'
DATABASE_URL=postgres://postgres:locationsharing%40123@192.168.0.95:40432/location_sharing?options=-c%20TimeZone%3DAsia%2FShanghai&sslmode=disable&connect_timeout=5&application_name=location-sharing-api
REDIS_URL=redis://192.168.0.95:40379
JWT_SECRET=locationsharing-user
JWT_ADMIN_SECRET=locationsharing-admin
MQTT_HOST=192.168.0.95
MQTT_PORT=41883
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
